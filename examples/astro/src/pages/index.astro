---
// src/pages/index.astro — END-TO-END SSR demo for masonry-pretext.
//
// This page demonstrates the FULL pretext + computeLayout + initLayout: false
// pipeline (PRETEXT_SSR_ROADMAP.md Phases 1-4):
//
//   1. The frontmatter (between the --- fences) runs in Node at build/request
//      time. We import Masonry, call Masonry.computeLayout with pre-measured
//      item sizes, and get back absolute (x, y) positions — IN PURE NODE,
//      with no DOM, no JSDOM, no chromium.
//
//   2. The body emits each item with inline `style="position: absolute;
//      left: Xpx; top: Ypx;"` so the browser renders the cascading-grid
//      layout BEFORE any client JavaScript runs.
//
//   3. A tiny client-side <script> constructs `new Masonry(grid, {
//      initLayout: false, static: true })`. With this combo, masonry adopts
//      the existing positions WITHOUT relayouting them, and skips wiring up
//      observers / animations / fonts.ready hooks. Result: ZERO HYDRATION
//      FLASH on first paint, plus zero relayout-on-resize cost.
//
// The natural follow-up is wiring `@chenglou/pretext` for real text-driven
// height computation:
//
//     import { prepare, layout } from '@chenglou/pretext';
//     const FONT = '14px/1.5 system-ui, sans-serif';
//     const sizes = items.map(item => {
//       const prepared = prepare(item.title, FONT);
//       const { height } = layout(prepared, COL_WIDTH, 21);
//       return { outerWidth: COL_WIDTH, outerHeight: height + 24 /* padding */ };
//     });
//
// The demo uses hardcoded heights instead so it has zero extra dependencies.
// Swapping in real pretext is one diff in the frontmatter.

import Masonry from 'masonry-pretext';

const COL_WIDTH = 240;
const GUTTER = 16;
const COLS = 3;
const CONTAINER_WIDTH = COLS * COL_WIDTH + (COLS - 1) * GUTTER; // 752

type Item = { id: string; title: string; outerHeight: number };

// In a real app these come from a CMS / database / file. Heights would
// typically come from `pretext.layout(...)` over the item text. For the
// demo we use deterministic pseudo-random heights so the layout is the
// same on every render and the CLS comparison is reproducible.
const items: Item[] = Array.from({ length: 24 }, (_, i) => ({
  id: String(i),
  title: `Item ${i + 1}`,
  outerHeight: 80 + ((i * 37) % 220),
}));

// THE KILLER STEP — server-side layout precomputation in pure Node.
// `Masonry.computeLayout` (#017 / Phase 2) takes pre-measured sizes
// and returns absolute positions, byte-for-byte identical to what
// the browser would compute on the client. No DOM, no instance.
const { positions, containerHeight } = Masonry.computeLayout({
  items: items.map((item) => ({
    outerWidth: COL_WIDTH,
    outerHeight: item.outerHeight,
  })),
  containerWidth: CONTAINER_WIDTH,
  columnWidth: COL_WIDTH,
  gutter: GUTTER,
});
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>masonry-pretext + Astro — zero-flash SSR demo</title>
    <meta name="description" content="Cascading grid layout with zero hydration flash, computed entirely on the server via Masonry.computeLayout + pretext." />
    <style>
      body { font-family: system-ui, sans-serif; padding: 24px; max-width: 900px; margin: 0 auto; }
      h1 { font-size: 24px; }
      h2 { font-size: 18px; margin-top: 32px; }
      p { line-height: 1.5; max-width: 720px; }
      code { background: #f3f4f6; padding: 1px 6px; border-radius: 4px; font-size: 13px; }

      .grid {
        position: relative;
        /* Reserve the full server-computed height so there is no layout
           shift when the items render. This is the secret to CLS = 0.00. */
        height: var(--grid-height);
      }
      .grid-item {
        position: absolute;            /* matches Item._create's no-op assignment */
        width: 240px;
        background: #f3f4f6;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 12px;
        box-sizing: border-box;
        font-size: 14px;
      }
    </style>
  </head>
  <body>
    <h1>masonry-pretext + Astro — zero-flash SSR</h1>

    <p>
      This grid is laid out <strong>entirely on the server</strong>, before
      any JavaScript runs in the browser. <code>Masonry.computeLayout</code>
      runs in Astro's Node frontmatter, returns absolute <code>(x, y)</code>
      positions, and the page emits them inline as
      <code>style="left: Xpx; top: Ypx;"</code> on each item.
    </p>

    <p>
      A tiny client-side <code>&lt;script&gt;</code> then constructs
      <code>new Masonry(grid, &#123; initLayout: false, static: true &#125;)</code>
      to <em>adopt</em> the existing positions without relayouting. The user
      sees the final cascading layout on first paint — there is no flow-to-
      absolute reflow, no hydration flash, no animated settle.
    </p>

    <h2>The grid</h2>

    <div class="grid" id="masonry-grid" style={`--grid-height: ${containerHeight}px`}>
      {items.map((item, i) => (
        <div
          class="grid-item"
          style={`left: ${positions[i].x}px; top: ${positions[i].y}px; height: ${item.outerHeight}px;`}
        >
          {item.title}
        </div>
      ))}
    </div>

    <h2>How it works</h2>

    <ul>
      <li>
        <strong>Frontmatter (Node):</strong> imports
        <code>masonry-pretext</code>, calls
        <code>Masonry.computeLayout(&#123; items, containerWidth, columnWidth, gutter &#125;)</code>,
        gets back <code>positions</code> + <code>containerHeight</code>.
      </li>
      <li>
        <strong>Server-rendered HTML:</strong> each item gets inline
        <code>left</code> + <code>top</code> from the computed positions.
        The container reserves <code>height: var(--grid-height)</code> so
        there is no vertical layout shift during hydration.
      </li>
      <li>
        <strong>Client &lt;script&gt;:</strong>
        <code>new Masonry(grid, &#123; initLayout: false, static: true &#125;)</code>
        adopts the SSR positions in place. Verified by improvement #018's
        discriminating fixture: items pre-positioned in any shape stay where
        the server placed them.
      </li>
    </ul>

    <p>
      With this pipeline, the cumulative layout shift (CLS) score for the
      grid section is <strong>0.00</strong>. Compare this to the same demo
      with the server rendering items in normal flow and masonry running on
      the client (the "before" pattern in <code>../../README.md#hydration-flash-and-how-to-reduce-it</code>),
      where CLS is typically ~0.10–0.15 even with <code>transitionDuration: 0</code>.
    </p>

    <script>
      // Astro bundles <script> blocks via Vite/esbuild. This runs ONLY
      // in the browser. The masonry-pretext ESM entry (dist/masonry.mjs,
      // shipped since #013) imports cleanly here.
      import Masonry from 'masonry-pretext';

      const grid = document.querySelector('#masonry-grid');
      if (grid) {
        // Stored on window only so HMR reloads can dispose the old
        // instance. Not needed for production.
        const anyWin = window as unknown as { __msnry?: { destroy(): void } };
        anyWin.__msnry?.destroy();

        anyWin.__msnry = new Masonry(grid, {
          itemSelector: '.grid-item',
          columnWidth: 240,
          gutter: 16,
          // THE KEY COMBO for the SSR adoption path:
          //
          //   initLayout: false  → don't run the constructor's layout()
          //                        pass; adopt existing positions instead
          //   static: true       → no observers, no animations, no font
          //                        hooks; the SSR positions are final
          //
          // Verified by the init-layout-false discriminating fixture (#018)
          // and the static-mode discriminating fixture (#015). Together they
          // form the conjugate pair that locks in the SSR adoption contract.
          initLayout: false,
          static: true,
        });
      }
    </script>
  </body>
</html>
